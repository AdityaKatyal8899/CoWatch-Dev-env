# ==========================================
# CoWatch Production Environment Template
# ==========================================

# 1. API CONFIG
PORT=8000
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# 2. DATABASE (SUPABASE)
# Use your Supabase Connection String (Transaction mode recommended)
DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:6543/postgres?sslmode=require

# 3. REDIS (INTERNAL DOCKER)
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 4. STORAGE PATHS (DOCKER VOLUMES)
# These match the volume mounts in docker-compose.yaml
HLS_OUTPUT_DIR=/app/outputs
STORAGE_DIR=/app/storage

# 5. GOOGLE AUTH
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 6. APP SECRETS
SECRET_KEY=generate-a-secure-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
